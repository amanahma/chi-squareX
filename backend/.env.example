# Google Meet AI Scribe — Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server port (default: 5001, auto-increments if in use)
PORT=5001

# JWT secret key for authentication
SECRET_KEY=change-this-to-a-strong-secret-key

# Google Gemini API Key (required for AI summarization)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI API key (optional, enables audio transcription fallback via Whisper)
# If unset, backend will keep caption-only mode and log STT as skipped.
OPENAI_API_KEY=

# ─── Chrome Profile for Google Meet Bot ────────────────────────────────────
#
# The bot needs a signed-in Google account to join meetings.
# It uses a Chrome profile directory — NOT your main running Chrome.
#
# RECOMMENDED SETUP (one-time, 2 minutes):
#
#   Step 1: Create a dedicated bot profile
#     Open CMD or PowerShell and run:
#       chrome.exe --user-data-dir="C:\MeetBot" --profile-directory="Default"
#
#     (For Edge, use:)
#       msedge.exe --user-data-dir="C:\MeetBot" --profile-directory="Default"
#
#   Step 2: Sign into your Google account in the new Chrome window
#
#   Step 3: Close that Chrome window completely
#
#   Step 4: Set these values in your .env:
#     CHROME_USER_DATA_DIR=C:/MeetBot
#     PROFILE_DIRECTORY=Default
#
# IMPORTANT:
#   - Do NOT use your main Chrome profile path (it will be locked while Chrome is open)
#   - The dedicated profile at C:\MeetBot is separate and won't conflict
#   - You only need to sign in ONCE — the session persists
#
# CHROME_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
# CHROME_USER_DATA_DIR=C:/MeetBot
# PROFILE_DIRECTORY=Default

# How long the bot can stay in a meeting before forced safety exit (default: 4h)
# MAX_MEETING_DURATION_MS=14400000

# SQLite database path (default: ./meetai.db)
# DATABASE_PATH=./meetai.db

# ─── Caption Watcher Recovery Tuning ───────────────────────────────────────
# Seconds of no captions before recovery is triggered (default: 60s)
# CAPTION_WATCHER_INACTIVITY_MS=60000

# How often to log a watcher heartbeat (default: 15s)
# CAPTION_WATCHER_HEARTBEAT_MS=15000

# Max reattachment attempts before giving up and activating poll fallback (default: 4)
# CAPTION_WATCHER_MAX_RECOVERY_ATTEMPTS=4

# How long to wait after reattach to validate that real caption events arrived (default: 8s)
# CAPTION_WATCHER_VALIDATION_MS=8000

# Base backoff between retries — grows linearly (attempt 1=5s, 2=10s, ...) (default: 5s)
# CAPTION_WATCHER_BACKOFF_MS=5000
